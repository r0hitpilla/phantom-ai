# PHANTOM AI — Environment Variables
# Copy this file to .env and fill in your values

# Required: Anthropic API key for Claude AI features
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: ElevenLabs for voice synthesis (future feature)
ELEVENLABS_API_KEY=

# Optional: Shodan for infrastructure intelligence (future feature)
SHODAN_API_KEY=

# Platform login password (default: phantom2024)
PHANTOM_PASSWORD=phantom2024

# Flask secret key — change this in production
SECRET_KEY=phantom-ai-secret-change-me-in-production

# Flask settings
FLASK_DEBUG=false
PORT=5000
